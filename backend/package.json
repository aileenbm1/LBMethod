{
  "name": "lbmethod-engine",
  "version": "1.0.0",
  "description": "LBMethodEngine - Professional training programming engine for female glute hypertrophy and lower-body focused routines.",
  "license": "MIT",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/src/api/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "engine:demo": "ts-node src/examples/usage.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "prisma": "^5.18.0",
    "typescript": "5.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/helmet": "^0.0.48",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
