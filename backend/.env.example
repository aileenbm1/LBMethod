# Base de datos (Railway la genera automáticamente)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
USE_DB=true

# Servidor
PORT=3000
NODE_ENV=production

# Seguridad JWT (generar con: openssl rand -base64 48)
JWT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_DE_48_CHARS
JWT_EXPIRES_IN=12h

# Admin (para crear coaches via POST /api/admin/coach)
ADMIN_SECRET=CAMBIAR_POR_SECRETO_ADMIN_SEGURO

# CORS (dominio del frontend en Vercel)
CORS_ORIGIN=https://tu-app.vercel.app

# SMTP para 2FA por email (opcional en desarrollo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=contraseña-de-aplicacion-google
SMTP_FROM=LB Method <noreply@lbmethod.com>
